	function myFunction() {
    	var input, filter, ul, li, a, i,div;
    	input = document.getElementById("myInput");
    	filter = input.value.toUpperCase();
    	ul = document.getElementById("secaccordion");
    	li = ul.getElementsByClassName("title");
    	divlist = document.getElementsByClassName("secList");
    	for (i = 0; i < li.length; i++) {
        	a = li[i].getElementsByTagName("a")[0];        
       		if (a.innerHTML.toUpperCase().indexOf(filter) > -1) {
            	li[i].style.display = "";
               	divlist[i].style.display="";
        	}else {
           		
           	 	li[i].style.display = "none";
            	divlist[i].style.display="none";
        	}
    	}
	}

    

    var search_count=0;
	$("#myInput").keyup(function(){
 
        // Retrieve the input field text and reset the count to zero
        var filter = $(this).val(), count = 0;
 
        // Loop through the comment list
        $(".sectionTitle").each(function(){
 
            // If the list item does not contain the text phrase fade it out
            if ($(this).text().search(new RegExp(filter, "i")) < 0) {
                $(this).fadeOut();
 
            // Show the list item if the phrase matches and increase the count by 1
            } else {
                $(this).show();
                count++;
            }
        });
 
        // Update the count
        var numberItems = count;
        search_count=numberItems;
        $("#filter-count").text("Number of Match Found = "+count);
    });

	var backSecId="";
	$("#bckbtn").click(function (){
		showOne(backSecId);
		$("#"+backSecId + " .in").collapse('hide');
		$("#bckbtn").hide();
	});
	

	
		$('body').on('click','.secbtn',function(){
		
		
		backSecId=$(this).parent().attr("id");
		titleid = $(this).parent().attr("id");
		showOne($(this).parent().attr("id"));
		
	});

	$('.hideshowsection').click(function(){
		
	});

	function showOne(id) {
		console.log(id);
	    $('.hideshowsection').not('#' + id).toggle();
	}
	$("#sal").click(function(){
		
		$("#myInput").val("");
		if(search_count==0){
				showOne(titleid);
				$("#"+titleid + " .in").collapse('hide');
				$("#sal").hide();
				 search_count=0;
		}else{
			
			 
 			
 			location.reload();
		        
		}
		
		
	});

	$('[data-tooltip="tooltip"]').tooltip();
	});
	
	
</script>
