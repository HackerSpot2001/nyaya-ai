<script>
$(document).ready(function() {
	var titleid="";
	$("#sal").hide();
	$("#bckbtn").hide();
	$("#showallchapterindex").hide();
	
	/* this is for section tab */
	$('body').on('click','.sectionTitle',function()
	{
		$(this).css("","");
		var result = $(this).attr("id");
		var res=  result.split("#",4);
		var act_id=res[0];
		var secId = res[1];
		var orgactid = res[2];
		var handle = res[3];
		
		
		queryParam = 'actid='+act_id+'&sectionID='+secId;
		 
		$.ajax({
		    type : 'GET',
		    url : '/SectionPageContent',
		    data : queryParam,
		    async: false,
		    success : function(msg) {
		    	   $("#secp"+secId).html(msg.content);
		           $("#secf"+secId).html(msg.footnote)
		    }
		});
			
			 queryParam1 = 'actid='+act_id+'&sectionID='+secId+'&orgactid='+orgactid;
			 
		$.ajax({
		    type : 'GET',
		    url : '/sectionlink',
		    data : queryParam1,
		    success : function(msg) {
		        
		        $("#"+secId).html(msg);
		    }
		});
	});
	 /* this is for geting preamble  */
	 $('body').on('click','.preambletitle',function()
			{
				$('#col8').hide();
				$("#showallchapterindex").show();
				$('#chapterid').show();
				$(this).css("","");
				var result = $(this).attr("id");
			
				
				var queryParam = 'actid='+result;
		        $.ajax({
		            type : 'GET',
		            url : '/ActPreambleServlet',
		            data : queryParam,
		            success : function(msg) {
		            	   $("#chapterid").html(msg);    
		            }
		        });
				
			});
	/* this is chapter index wise section  */
	$('body').on('click','.headingone',function()
			{
				$('#col8').hide();
				$("#showallchapterindex").show();
				$('#chapterid').show();
				$(this).css("","");
				var result = $(this).attr("id");
				var res=  result.split("#",3);
				var act_id=res[0];
				var h1id = res[1];
				var orgID = res[2];
				
				var abbervation='CEN';
				var collectionHandle='123456789/1362';
				var queryParam = 'abv='+abbervation+'&statehandle='+collectionHandle+'&actid='+act_id+'&h1id='+h1id+'&h2id='+h1id+'&h3id='+h1id+'&h4id='+h1id+'&orgactid='+orgID+'&headingno=headingone';
	        $.ajax({
		            type : 'GET',
		            url : '/ChapterIndexWiseSection',
		            data : queryParam,
		            success : function(msg) {
		            	   $("#chapterid").html(msg);    
		            }
		        });
		        setTimeout(function() {
	            	  if(!$.fn.DataTable.isDataTable('#myTableActChapterIndexSection')){
	            		  $('#myTableActChapterIndexSection').DataTable({
	                          "ordering":false
	                      });
	            		  
	            	  }
	            	 
	            	}, 500);
			});
	$('body').on('click','.headingtwo',function()
			{
				$('#col8').hide();
				$("#showallchapterindex").show();
				$('#chapterid').show();
				$(this).css("","");
				var result = $(this).attr("id");
				var res=  result.split("#",4);
				var act_id=res[0];
				var h1id = res[1];
				var h2id = res[2];
				var orgID = res[3];
				
				
