<script>
function changelang(e){
	var dataa={};
	dataa['lagtype']=e;
	$.ajax({
        type: "POST",
        url: base_url+'lang',
        data: dataa,
        cache: false,
        success: function (resp) {
		     setTimeout(function(){
                window.location.href = base_url;
             }, 250);
        },
	}); 
}
</script>

